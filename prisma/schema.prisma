generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
// prisma/schema.prisma (핵심 모델 파트)

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}
enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model WorkspaceInvite {
  id            String                 @id @default(cuid())

  workspaceId   Int
  inviterId     String
  inviteeUserId String

  role          WorkspaceRole          @default(MEMBER)
  status        WorkspaceInviteStatus  @default(PENDING)

  respondedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter       User                   @relation("WorkspaceInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee       User                   @relation("WorkspaceInviteInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([inviteeUserId])
  @@index([workspaceId, inviteeUserId])
}

model User {
  id            String    @id @default(cuid())
  email       String?            @unique
  password    String?
  name        String?
  image       String?
  color       String?
  emailVerified DateTime?
  sentWorkspaceInvites     WorkspaceInvite[] @relation("WorkspaceInviteInviter")
  receivedWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInviteInvitee")
  accounts      Account[]
  sessions      Session[]

  memberships WorkspaceMember[]
  pages       Page[]            @relation("PageAuthor")
  deletedPages Page[]           @relation("PageDeleter")

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Workspace {
  id        Int               @id @default(autoincrement())
  name      String            
  type      WorkspaceType     @default(PERSONAL)

  members   WorkspaceMember[]
  pages     Page[]

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invites   WorkspaceInvite[]
}

model WorkspaceMember {
  userId      String
  workspaceId Int
  role        WorkspaceRole    @default(MEMBER)
  joinedAt    DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 같은 유저가 같은 워크스페이스에 중복 가입 방지
  @@id([userId, workspaceId])
  @@index([workspaceId])
}

model Page {
  id          Int       @id @default(autoincrement())

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 페이지 트리 (부모-자식)
  parentId    Int?
  parent    Page?  @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[] @relation("PageTree")
  // 작성자 (유저 삭제/탈퇴 대비해서 nullable)
  authorId    String?
  author      User?     @relation("PageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  title       String
  icon        String?

  // 같은 부모 아래 정렬(드래그앤드롭에 필요)
  order       Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ispublished  Boolean   @default(false)
  publictoken String?   @unique
  deletedAt   DateTime?
  deletedBy   String?
  deletedByUser User?   @relation("PageDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)


  snapshots PageSnapshot[]

  @@index([workspaceId])
  @@index([parentId])
  @@index([authorId])
  @@index([deletedBy])
  @@index([workspaceId, parentId, order])
  @@index([workspaceId, parentId, order, deletedAt])
}

model PageSnapshot {
  id          Int      @id @default(autoincrement())
  pageId      Int
  version     Int
  contentJson Json
  createdAt   DateTime @default(now())

  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
  @@index([pageId])
}



model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 

}


model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}
