{
  "family": "example1",
  "containerDefinitions": [
    {
      "name": "example",
      "image": "990678687582.dkr.ecr.ap-northeast-2.amazonaws.com/teamspace",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "name": "example-3000-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "secrets": [
        {
          "name": "ADMIN_EMAILS",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:ADMIN_EMAILS::"
        },
        {
          "name": "AUTH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:AUTH_SECRET::"
        },
        {
          "name": "AUTH_TRUST_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:AUTH_TRUST_HOST::"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:DATABASE_URL::"
        },
        {
          "name": "HOSTNAME",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:HOSTNAME::"
        },
        {
          "name": "LIVEBLOCKS_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:LIVEBLOCKS_SECRET_KEY::"
        },
        {
          "name": "TURNSTILE_SITE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:TURNSTILE_SITE_KEY::"
        },
        {
          "name": "TURNSTILE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:TURNSTILE_SECRET_KEY::"
        },
        {
          "name": "AUTH_GOOGLE_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:AUTH_GOOGLE_ID::"
        },
        {
          "name": "AUTH_GOOGLE_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:990678687582:secret:teamspace-AMbgCS:AUTH_GOOGLE_SECRET::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/teamspace",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "taskRoleArn": "arn:aws:iam::990678687582:role/ECS-role-aeb6b4ec",
  "executionRoleArn": "arn:aws:iam::990678687582:role/service-role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
